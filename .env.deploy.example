# Copy this file to .env.deploy and edit values before deploying.

# Ports exposed on host
FRONTEND_PORT=3000
BACKEND_PORT=8080

# Database
MYSQL_DATABASE=calorie_tracking_app
MYSQL_ROOT_PASSWORD=change_this_to_a_strong_password

# Frontend API base. Keep empty when using reverse-proxy /api through frontend container.
REACT_APP_API_BASE=
FRONTEND_BACKEND_BASE_URL=http://backend:8080

# CORS: set your real domains/IPs in production (comma-separated)
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://127.0.0.1:3000
