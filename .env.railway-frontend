# Railway frontend service variables template.
# Example assumes backend service name is: backend

# Keep empty to use same-origin /api from nginx reverse proxy.
REACT_APP_API_BASE=

# nginx runtime backend target (service-to-service private network)
BACKEND_BASE_URL=http://${{backend.RAILWAY_PRIVATE_DOMAIN}}:8080

# Railway sets PORT automatically. Keep optional fallback.
PORT=80
